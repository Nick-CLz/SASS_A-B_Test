# Copy to .env and fill in. Never commit .env (it is gitignored).
# Each variable is consumed by the component noted in [brackets].

# ---- Core / app ----
APP_ENV=local                       # [backend] local | staging | production
APP_SECRET_KEY=change-me-please     # [backend] signing key for tokens/sessions
LOG_LEVEL=INFO                      # [backend] DEBUG | INFO | WARNING | ERROR

# ---- Metadata database (Postgres) ----
DATABASE_URL=postgresql+psycopg://mallard:mallard@localhost:5432/mallard   # [backend]

# ---- Analytics engine (DuckDB) ----
DUCKDB_PATH=./data/analytics.duckdb # [backend/stats] embedded analytics store for the demo
# In production you point the analytics layer at a warehouse instead; see docs/02-architecture.md
# WAREHOUSE_KIND=duckdb             # duckdb | bigquery | snowflake | databricks
# WAREHOUSE_DSN=

# ---- Anthropic / Claude (AI agents) ----
ANTHROPIC_API_KEY=                  # [backend/agents] required for the AI agent layer
AGENT_MODEL_SMALL=claude-haiku-4-5-20251001   # routing: cheap/fast tasks
AGENT_MODEL_MEDIUM=claude-sonnet-4-6          # routing: default reasoning
AGENT_MODEL_LARGE=claude-opus-4-8             # routing: hard design/analysis tasks
AGENT_ENABLE_PROMPT_CACHING=true              # cache system prompts + data context

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000   # [frontend] where the dashboard calls the API

# ---- Auth (SaaS phase; can be stubbed for the MVP) ----
# AUTH_PROVIDER=stub                # stub | jwt | clerk
# JWT_SECRET=
